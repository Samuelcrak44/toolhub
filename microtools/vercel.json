{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/h/:slug", "destination": "/index.html" },
    { "source": "/c/:cat",  "destination": "/index.html" }
  ],
  "headers": [
    { "source": "/(css|js)/(.*)", "headers": [
      { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
    ]}
  ]
}
